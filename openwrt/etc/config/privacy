# privacy — paths for killswitch / Tor helper scripts (copy to /etc/config/privacy)

config privacy 'main'
	option enabled '1'
	option wg_if 'wg0'
	option require_tor '1'
	option require_wg '1'
	# Logical interfaces (see ip link); Puli: wwan0 via apply-device-profile; Slate AX: often empty
	option lan_dev 'br-lan'
	option wan_dev ''
	option vendor_gl_vpn_killswitch 'leave'
