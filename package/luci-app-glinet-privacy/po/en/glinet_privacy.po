msgstr "Modem serial device"

msgid "AT port for Quectel (often ttyUSB2). Empty = same scan order as rotate_imei.sh."
msgstr "AT port for Quectel (often ttyUSB2). Empty = same scan order as rotate_imei.sh."

msgid "Auto (scan /dev/ttyUSB* then /dev/ttyACM*)"
msgstr "Auto (scan /dev/ttyUSB* then /dev/ttyACM*)"

msgid "saved"
msgstr "saved"

msgid "WWAN logical interface"
msgstr "WWAN logical interface"

msgid "Which Network → Interfaces section to restart after IMEI write. Empty = same auto-detect as rotate_imei.sh (wwan / 4g / modem / cellular, or first wwan/3g/qmi/mbim/ncm)."
msgstr "Which Network → Interfaces section to restart after IMEI write. Empty = same auto-detect as rotate_imei.sh (wwan / 4g / modem / cellular, or first wwan/3g/qmi/mbim/ncm)."

