msgid "WireGuard (%s)"
msgstr "WireGuard (%s)"

msgid "Boot-time or cron rotation for Quectel modems via AT+EGMR. Altering IMEI may be unlawful outside operator-authorized or lab use; you are responsible for compliance. See docs/devices.md (IMEI section) in the project repository. Firmware may reject writes. Optional: set ROTATE_IMEI_SUPPRESS_LEGAL_LOG=1 on cron after you have verified compliance."
msgstr "Boot-time or cron rotation for Quectel modems via AT+EGMR. Altering IMEI may be unlawful outside operator-authorized or lab use; you are responsible for compliance. See docs/devices.md (IMEI section) in the project repository. Firmware may reject writes. Optional: set ROTATE_IMEI_SUPPRESS_LEGAL_LOG=1 on cron after you have verified compliance."

msgid "Settings"
msgstr "Settings"

msgid "Auto-detection"
msgstr "Auto-detection"

msgid "Cellular (Puli) — IMEI rotation applies when modem is present."
msgstr "Cellular (Puli) — IMEI rotation applies when modem is present."

msgid "Travel router profile — no built-in modem; leave rotation off unless you use USB cellular."
msgstr "Travel router profile — no built-in modem; leave rotation off unless you use USB cellular."

msgid "No readable /dev/ttyUSB* or /dev/ttyACM* — modem not connected or permissions."
msgstr "No readable /dev/ttyUSB* or /dev/ttyACM* — modem not connected or permissions."

msgid "No network interfaces in UCI."
msgstr "No network interfaces in UCI."

msgid "Run on boot"
msgstr "Run on boot"

msgid "Uses /etc/init.d/rotate_imei when enabled."
msgstr "Uses /etc/init.d/rotate_imei when enabled."

msgid "Cron: rotate on a schedule"
msgstr "Cron: rotate on a schedule"

msgid "Adds one line to /etc/crontabs/root for /usr/bin/rotate_imei.sh. Requires a system cron daemon (scheduled tasks). Interval is configured below."
msgstr "Adds one line to /etc/crontabs/root for /usr/bin/rotate_imei.sh. Requires a system cron daemon (scheduled tasks). Interval is configured below."

msgid "Hours between cron rotations"
msgstr "Hours between cron rotations"

msgid "Crontab runs at minute 0 each period (1 = every hour at :00; 24 = once daily at midnight; other values use 0 */N * * *)."
msgstr "Crontab runs at minute 0 each period (1 = every hour at :00; 24 = once daily at midnight; other values use 0 */N * * *)."

msgid "Suppress legal notice in syslog (cron)"
msgstr "Suppress legal notice in syslog (cron)"

msgid "Prefixes the cron command with ROTATE_IMEI_SUPPRESS_LEGAL_LOG=1 (use only after you have verified legal compliance)."
msgstr "Prefixes the cron command with ROTATE_IMEI_SUPPRESS_LEGAL_LOG=1 (use only after you have verified legal compliance)."

