msgstr "Symlinks /etc/glinet-privacy/glinet-block.conf into /etc/dnsmasq.d/."

msgid "Disable GL.iNet cloud (UCI + services)"
msgstr "Disable GL.iNet cloud (UCI + services)"

msgid "Sets glconfig.cloud.enable=0 where present, stops gl_cloud / goodcloud init scripts, and installs DNS black-holes via /etc/dnsmasq.d/glinet-block.conf (same as reference: goodcloud.xyz, gldns.com)."
msgstr "Sets glconfig.cloud.enable=0 where present, stops gl_cloud / goodcloud init scripts, and installs DNS black-holes via /etc/dnsmasq.d/glinet-block.conf (same as reference: goodcloud.xyz, gldns.com)."

msgid "Remove cloud packages (opkg)"
msgstr "Remove cloud packages (opkg)"

msgid "When saving telemetry settings, best-effort uninstall of gl-cloud and related packages (optional; may affect stock GL.iNet features)."
msgstr "When saving telemetry settings, best-effort uninstall of gl-cloud and related packages (optional; may affect stock GL.iNet features)."

