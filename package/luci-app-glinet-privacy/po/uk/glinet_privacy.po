msgid "Boot-time or cron rotation for Quectel modems via AT+EGMR. Altering IMEI may be unlawful outside operator-authorized or lab use; you are responsible for compliance. See docs/devices.md (IMEI section) in the project repository. Firmware may reject writes. Optional: set ROTATE_IMEI_SUPPRESS_LEGAL_LOG=1 on cron after you have verified compliance."
msgstr ""

msgid "Settings"
msgstr ""

msgid "Auto-detection"
msgstr ""

msgid "Cellular (Puli) — IMEI rotation applies when modem is present."
msgstr ""

msgid "Travel router profile — no built-in modem; leave rotation off unless you use USB cellular."
msgstr ""

msgid "No readable /dev/ttyUSB* or /dev/ttyACM* — modem not connected or permissions."
msgstr ""

msgid "No network interfaces in UCI."
msgstr ""

msgid "Run on boot"
msgstr ""

msgid "Uses /etc/init.d/rotate_imei when enabled."
msgstr ""

msgid "Cron: rotate on a schedule"
msgstr ""

msgid "Adds one line to /etc/crontabs/root for /usr/bin/rotate_imei.sh. Requires a system cron daemon (scheduled tasks). Interval is configured below."
msgstr ""

msgid "Hours between cron rotations"
msgstr ""

msgid "Crontab runs at minute 0 each period (1 = every hour at :00; 24 = once daily at midnight; other values use 0 */N * * *)."
msgstr ""

msgid "Suppress legal notice in syslog (cron)"
msgstr ""

msgid "Prefixes the cron command with ROTATE_IMEI_SUPPRESS_LEGAL_LOG=1 (use only after you have verified legal compliance)."
msgstr ""

msgid "Modem serial device"
msgstr ""

msgid "AT port for Quectel (often ttyUSB2). Empty = same scan order as rotate_imei.sh."
msgstr ""

