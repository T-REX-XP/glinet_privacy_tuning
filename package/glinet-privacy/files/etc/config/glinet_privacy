# GL.iNet Privacy — Tor / firewall / telemetry (LuCI + CLI)
# Device profile: apply-device-profile.sh sets hw.slug (puli_xe300, slate_ax1800, …)

config device 'hw'
	option slug 'auto'
	option auto_wan '1'
	option board_hint ''

config firewall 'tor'
	option tor_transparent '0'
	option lan_cidr '192.168.8.0/24'
	option router_lan_ip '192.168.8.1'
	option lan_dev ''
	option tor_trans_port '9040'
	option tor_dns_port '9053'

config telemetry 'tel'
	option block_domains '0'
	option disable_vendor_cloud '0'
	# Best-effort opkg remove (gl-cloud, …) when disable_vendor_cloud runs; can break stock GL.iNet UI
	option remove_cloud_packages '0'

# Optional read-only ubus snapshots on LuCI (Overview / Tor-DNS); see docs/vendor-ubus.md
config vendor_ubus 'vendor_ubus'
	option enabled '0'
	option min_release_substr ''

# DNS: optional tor_dnsmasq (use with Tor running); else leave default
config dns 'dns'
	option dns_policy 'default'
	# Redirect LAN TCP/53 to Tor DNSPort (same idea as UDP; many clients use UDP only)
	option redirect_tcp_dns '1'
	# Drop LAN→forwarded TCP/853 (DoT) to non-router; can break intentional DoT — off by default
	option block_lan_dot '0'
